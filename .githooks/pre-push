#!/usr/bin/env sh
set -eu

# Run full mojibake check before push.
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File tools/check-mojibake.ps1 -Root .
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File tools/check-mojibake.ps1 -Root .
else
  echo "ERROR: Neither pwsh nor powershell was found. Cannot run encoding check." >&2
  exit 1
fi
