#!/usr/bin/env sh
set -eu

# Run local mojibake check before commit.
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File tools/check-mojibake.ps1 -Root . -StagedOnly
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File tools/check-mojibake.ps1 -Root . -StagedOnly
else
  echo "ERROR: Neither pwsh nor powershell was found. Cannot run encoding check." >&2
  exit 1
fi
